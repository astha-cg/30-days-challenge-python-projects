#To validate email
def emailValidation(email):

    k,j,d=0,0,0
     #to test that atleast 6 characters are present
    if len(email)>=6: 
        #Test alphabate at the first position
        if email[0].isalpha():
            #Test @ present and should occur atmost one
            if ("@" in email) and (email.count('@')==1):
                #Test "." present in the last third position (e.g. (.in)) or present in the forth position(e.g. (.com))
                if (email[-3]=='.') ^ (email[-4]=='.'):
                    for i in email:
                        #Test if any space present
                        if (i==i.isspace()):
                            k=1
                        # Test if any alphabat present
                        elif i.isalpha():
                            if i==i.isupper():
                                j=1
                        #Test if any digit present
                        elif i.isdigit():
                            continue
                        elif i=="_" or i=="." or i=="@":
                            continue
                        else:
                            d=1
                    if k==1 or j==1 or d==1:
                        print("Wrong Email 5")
                        return False

                else:
                    print("Wrong Email 4")
                    return False
            else:
                print("Wrong Email 3")
                return False
        else:
            print("Wrong Email 2")
            return False

    else:
        print("Wrong Email 1")
        return False

if __name__=="__main__":
    email=input("Enter your Email : ")#g@g.in , wscube@gamil.com
