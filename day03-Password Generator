#program to generate random password of variable length
import random
import string
again=1
def strong_password(length):
    if length<4:
        return "Password length must be at least 4."
    
    password=[
        random.choice(string.ascii_uppercase), #choice random charater from A-Z
        random.choice(string.ascii_lowercase), #choice random charater from a-z
        random.choice(string.digits), #choice random charater from 0-9
        random.choice(string.punctuation) #choice random charater from !@#$
    ]
    # password generate 4 character till here the remaining_length is added from below
    remaining_length=length-4
    all_characters=string.ascii_letters + string.digits + string.punctuation
    password += random.choices(all_characters, k=remaining_length) #add all string together

    random.shuffle(password) #shuffle a sequence (list)
    return ''.join(password) 

while again==1:

    length= int (input("Enter password length: ")) #take length as input
    print("Generated strong Password:", strong_password(length))#function call


    again = int(input("Generate another? (0/1): "))
if again != 1:
    print("Goodbye 👋")
    
