from tkinter import *
import speedtest

def speedcheck():
    try:
        st = speedtest.Speedtest()
        st.get_best_server()

        lab_down.config(text="Testing...")
        lab_up.config(text="Testing...")
        sp.update()
        #------calculating speed---------
        down = str(round(st.download() / (10**6), 2)) + " Mbps"
        lab_down.config(text=down)

        up = str(round(st.upload() / (10**6), 2)) + " Mbps"
        lab_up.config(text=up)

    except Exception as e:
        lab_down.config(text="Error")
        lab_up.config(text="Error")
        print(e)


sp = Tk()
sp.title("Internet Speed Test")
sp.geometry("500x650")
sp.config(bg="blue")

Label(sp, text="Internet Speed Test", font=("Times New Roman", 30, "bold"), bg="blue", fg="white").place(x=60,y=40,width=380)

Label(sp, text="Download Speed", font=("Times New Roman", 25, "bold")).place(x=60,y=130,width=380)
lab_down = Label(sp, text="00", font=("Times New Roman", 25, "bold"))
lab_down.place(x=60,y=200,width=380)

Label(sp, text="Upload Speed", font=("Times New Roman", 25, "bold")).place(x=60,y=290,width=380)
lab_up = Label(sp, text="00", font=("Times New Roman", 25, "bold"))
lab_up.place(x=60,y=360,width=380)

Button(sp, text="Check Speed", font=("Times New Roman", 25, "bold"), bg="red", command=speedcheck).place(x=60,y=460,width=380)

sp.mainloop()
