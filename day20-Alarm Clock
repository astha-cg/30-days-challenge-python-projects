import tkinter as tk
from tkinter import messagebox
import datetime
import time
import threading
import winsound  # Windows only

def alarm():
    while True:
        set_time = f"{hour_entry.get()}:{minute_entry.get()}:00"
        current_time = datetime.datetime.now().strftime("%H:%M:%S")

        if current_time == set_time:
            messagebox.showinfo("⏰ Alarm", "Wake up! Time reached 🎉")
            for _ in range(5):
                winsound.Beep(1000, 1000)  # frequency, duration
            break

        time.sleep(1)

def set_alarm():
    t = threading.Thread(target=alarm)
    t.daemon = True
    t.start()
    status_label.config(text="✅ Alarm Set Successfully!")

# GUI
root = tk.Tk()
root.title("⏰ Alarm Clock")
root.geometry("350x250")

tk.Label(root, text="Set Alarm Time", font=("Arial", 16)).pack(pady=10)

frame = tk.Frame(root)
frame.pack()

hour_entry = tk.Entry(frame, width=5)
hour_entry.grid(row=0, column=0, padx=5)

tk.Label(frame, text=":").grid(row=0, column=1)

minute_entry = tk.Entry(frame, width=5)
minute_entry.grid(row=0, column=2, padx=5)

tk.Button(root, text="Set Alarm", command=set_alarm).pack(pady=20)

status_label = tk.Label(root, text="", font=("Arial", 12))
status_label.pack()

root.mainloop()
